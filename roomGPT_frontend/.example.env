# Optional override. Leave empty to use auto mode:
# - local page (localhost/127.0.0.1) -> http://localhost:8000
# - non-local page (e.g. http://124.221.23.45:3000) -> http://<same-host>:8000
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_IMAGE_GENERATION_MODE=local_mock

# Legacy optional variables (only if you still use app/generate/route.ts)
REPLICATE_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
